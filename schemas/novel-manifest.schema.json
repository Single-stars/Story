{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://story-os.local/schemas/novel-manifest.schema.json",
  "title": "Story OS novel manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "novel_id",
    "title",
    "slug",
    "status",
    "language",
    "genre",
    "premise",
    "structure",
    "dependencies",
    "current_focus",
    "paths",
    "sharing"
  ],
  "properties": {
    "schema_version": {
      "$ref": "https://story-os.local/schemas/common.schema.json#/$defs/semanticVersion"
    },
    "novel_id": {
      "$ref": "https://story-os.local/schemas/common.schema.json#/$defs/novelId"
    },
    "title": { "type": "string", "minLength": 1, "maxLength": 200 },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
      "maxLength": 80
    },
    "status": {
      "$ref": "https://story-os.local/schemas/common.schema.json#/$defs/novelStatus"
    },
    "language": { "type": "string", "minLength": 2 },
    "genre": {
      "type": "object",
      "additionalProperties": false,
      "required": ["primary", "secondary", "target_readers", "promises"],
      "properties": {
        "primary": { "type": "string", "minLength": 1, "maxLength": 80 },
        "secondary": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1, "maxLength": 80 }
        },
        "target_readers": {
          "type": "string",
          "minLength": 1,
          "maxLength": 500
        },
        "promises": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1, "maxLength": 300 }
        },
        "content_notes": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1, "maxLength": 200 }
        }
      }
    },
    "premise": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "logline", "theme_question", "core_conflict"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["idea", "proposed", "approved"]
        },
        "logline": { "type": "string", "minLength": 1, "maxLength": 500 },
        "theme_question": {
          "type": "string",
          "minLength": 1,
          "maxLength": 500
        },
        "core_conflict": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1000
        }
      }
    },
    "structure": {
      "type": "object",
      "additionalProperties": false,
      "required": ["lenses", "intended_length_words", "volumes"],
      "properties": {
        "lenses": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "intended_length_words": {
          "type": "integer",
          "minimum": 1000,
          "maximum": 10000000
        },
        "volumes": { "type": "integer", "minimum": 1, "maximum": 100 }
      }
    },
    "dependencies": {
      "type": "object",
      "additionalProperties": false,
      "required": ["universe_refs", "series_id"],
      "properties": {
        "universe_refs": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["universe_id", "version"],
            "properties": {
              "universe_id": {
                "$ref": "https://story-os.local/schemas/common.schema.json#/$defs/universeId"
              },
              "version": {
                "$ref": "https://story-os.local/schemas/common.schema.json#/$defs/semanticVersion"
              }
            }
          }
        },
        "series_id": {
          "anyOf": [
            { "type": "null" },
            {
              "$ref": "https://story-os.local/schemas/common.schema.json#/$defs/seriesId"
            }
          ]
        }
      }
    },
    "current_focus": {
      "type": "object",
      "additionalProperties": false,
      "required": ["volume", "chapter", "scene_id", "note"],
      "properties": {
        "volume": { "type": "integer", "minimum": 1 },
        "chapter": { "type": "integer", "minimum": 1 },
        "scene_id": {
          "anyOf": [
            { "type": "null" },
            { "type": "string", "pattern": "^SCN-[0-9]{4}$" }
          ]
        },
        "note": { "type": "string", "maxLength": 500 }
      }
    },
    "paths": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "canon",
        "narrative",
        "manuscript",
        "research",
        "decisions",
        "feedback",
        "reports"
      ],
      "properties": {
        "canon": { "$ref": "https://story-os.local/schemas/common.schema.json#/$defs/relativePath" },
        "narrative": { "$ref": "https://story-os.local/schemas/common.schema.json#/$defs/relativePath" },
        "manuscript": { "$ref": "https://story-os.local/schemas/common.schema.json#/$defs/relativePath" },
        "research": { "$ref": "https://story-os.local/schemas/common.schema.json#/$defs/relativePath" },
        "decisions": { "$ref": "https://story-os.local/schemas/common.schema.json#/$defs/relativePath" },
        "feedback": { "$ref": "https://story-os.local/schemas/common.schema.json#/$defs/relativePath" },
        "reports": { "$ref": "https://story-os.local/schemas/common.schema.json#/$defs/relativePath" }
      }
    },
    "sharing": {
      "type": "object",
      "additionalProperties": false,
      "required": ["default_profile", "allow_offline_reader"],
      "properties": {
        "default_profile": {
          "$ref": "https://story-os.local/schemas/common.schema.json#/$defs/visibility"
        },
        "allow_offline_reader": { "type": "boolean" }
      }
    }
  }
}

