{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://story-os.local/schemas/review-record.schema.json",
  "title": "Story OS review records",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "record_type",
    "owner",
    "status",
    "visibility",
    "canon_effect",
    "review_type",
    "scope",
    "source_version",
    "coverage",
    "findings",
    "conclusion",
    "author_decision",
    "reverification",
    "resume_brief"
  ],
  "properties": {
    "schema_version": {
      "$ref": "https://story-os.local/schemas/common.schema.json#/$defs/semanticVersion"
    },
    "id": {
      "type": "string",
      "pattern": "^REVIEW-[0-9]{4}$"
    },
    "record_type": {
      "type": "string",
      "const": "review_record"
    },
    "owner": {
      "type": "object",
      "additionalProperties": false,
      "required": ["novel_id"],
      "properties": {
        "novel_id": {
          "$ref": "https://story-os.local/schemas/common.schema.json#/$defs/novelId"
        }
      }
    },
    "status": {
      "type": "string",
      "enum": ["planned", "in_progress", "reviewed", "accepted", "blocked", "stale"]
    },
    "visibility": {
      "$ref": "https://story-os.local/schemas/common.schema.json#/$defs/visibility"
    },
    "canon_effect": {
      "type": "string",
      "const": "proposal_only"
    },
    "review_type": {
      "type": "string",
      "enum": [
        "continuity",
        "developmental_edit",
        "reader_test",
        "line_edit",
        "character",
        "worldbuilding",
        "outline",
        "custom"
      ]
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["novel_id", "chapter_ids", "entity_ids", "manuscript_paths"],
      "properties": {
        "novel_id": {
          "$ref": "https://story-os.local/schemas/common.schema.json#/$defs/novelId"
        },
        "chapter_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "pattern": "^CHAPTER-[0-9]{4}$" }
        },
        "entity_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^(CHAR|LOC|FACTION|ITEM|RULE|FACT|REL|KNOW|CSTATE|EVT|SCN|THREAD|FORESH)-[0-9]{4}$"
          }
        },
        "manuscript_paths": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "https://story-os.local/schemas/common.schema.json#/$defs/relativePath"
          }
        }
      }
    },
    "source_version": {
      "type": "object",
      "additionalProperties": false,
      "required": ["baseline_label", "content_hash", "reviewed_at"],
      "properties": {
        "baseline_label": { "type": "string", "minLength": 1, "maxLength": 200 },
        "content_hash": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "reviewed_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "coverage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["checked", "gaps"],
      "properties": {
        "checked": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "gaps": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["key", "severity", "status", "issue", "recommendation"],
        "properties": {
          "key": {
            "type": "string",
            "pattern": "^[A-Z]+-[0-9]{3}$"
          },
          "severity": {
            "type": "string",
            "enum": ["blocker", "major", "minor", "note"]
          },
          "status": {
            "type": "string",
            "enum": ["open", "accepted", "rejected", "fixed", "verified"]
          },
          "location": {
            "type": "string",
            "minLength": 1,
            "maxLength": 200
          },
          "issue": {
            "type": "string",
            "minLength": 1,
            "maxLength": 4000
          },
          "recommendation": {
            "type": "string",
            "minLength": 1,
            "maxLength": 4000
          }
        }
      }
    },
    "conclusion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["verdict", "summary", "blockers"],
      "properties": {
        "verdict": {
          "type": "string",
          "enum": ["pass", "pass_with_notes", "blocked", "inconclusive"]
        },
        "summary": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4000
        },
        "blockers": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "pattern": "^[A-Z]+-[0-9]{3}$" }
        }
      }
    },
    "author_decision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "decision_id", "notes"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["pending", "accepted", "rejected", "partially_accepted"]
        },
        "decision_id": {
          "type": ["string", "null"],
          "pattern": "^DEC-[0-9]{4}$"
        },
        "notes": {
          "type": "string",
          "maxLength": 4000
        }
      }
    },
    "reverification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "required_review_ids", "notes"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["not_required", "required", "passed", "failed"]
        },
        "required_review_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "pattern": "^REVIEW-[0-9]{4}$" }
        },
        "notes": {
          "type": "string",
          "maxLength": 4000
        }
      }
    },
    "resume_brief": {
      "type": "string",
      "minLength": 1,
      "maxLength": 4000
    }
  }
}
